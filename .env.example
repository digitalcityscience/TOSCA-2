# Base URL for the application
VITE_BASE_URL="/"
# MapTiler API Key (replace with your actual API key)
VITE_MAPTILER_API_KEY="your_maptiler_api_key"
# MapTiler API Map ID (replace with your desired map ID)
VITE_MAPTILER_API_MAP_ID="streets-v2"
# Starting longitude for the map
VITE_MAP_START_LNG="your_default_longitude"
# Starting latitude for the map
VITE_MAP_START_LAT="your_default_latitude"
# Starting zoom level for the map
VITE_MAP_START_ZOOM="your_default_zoom"
# Backend Root URL (replace with your backend's root URL)
VITE_BACKEND_ROOT_URL="http://your-backend-root-url"
# GeoNode REST URL (constructed using the backend root URL)
VITE_GEONODE_REST_URL="$VITE_BACKEND_ROOT_URL/api"
# GeoServer Base URL for WMS/WMTS map delivery only
VITE_GEOSERVER_BASE_URL="http://your-geoserver-root-url/geoserver"
